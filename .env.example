# Copy to .env.local (never commit .env.local)

# Canonical public URL for Open Graph / absolute metadata (production). Vercel sets VERCEL_URL if unset.
# NEXT_PUBLIC_APP_URL=https://your-argus.example.com
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional — default is gemini-2.0-flash (stable on AI Studio). Example: gemini-2.5-flash
# GEMINI_MODEL=

# VirusTotal v2 domain report — https://www.virustotal.com/gui/join-us
# Server uses GET ?apikey=&domain= per VT v2 API (key appears only in outbound request to VirusTotal).
VIRUSTOTAL_API_KEY=

# Optional — Google Programmable Search (Custom Search JSON API) for “Google dork” module
# Create a search engine at https://programmablesearchengine.google.com/ and enable the API.
# GOOGLE_CSE_API_KEY=
# GOOGLE_CSE_ID=

# --- Shared / production hardening (optional) ---
# If set, clients must send the same value as header x-argus-key or Authorization: Bearer <key>
# ARGUS_API_KEY=

# Per-IP rate limit (defaults are permissive if unset)
# ARGUS_RATE_LIMIT_WINDOW_MS=60000
# ARGUS_RATE_LIMIT_MAX=120

# Comma-separated hostname suffixes allowed for scans (empty = any public host per SSRF policy)
# ARGUS_ALLOWED_DOMAINS=example.com,sub.example.com

# Set to 1 to allow RFC1918 / loopback / metadata targets (lab only)
# ARGUS_ALLOW_PRIVATE_TARGETS=0

# Append-only style audit log lines to stdout (1 = on)
# ARGUS_AUDIT_LOG=0

# SSL/TLS scan result cache (short TTL, in-process)
# ARGUS_SSL_CACHE=1
# ARGUS_SSL_CACHE_TTL_MS=120000

# Optional: run Semgrep CLI during code review (requires `semgrep` on PATH or SEMGREP_PATH)
# ARGUS_ENABLE_SEMGREP=1
# SEMGREP_PATH=semgrep
# ARGUS_SEMGREP_TIMEOUT_MS=45000
